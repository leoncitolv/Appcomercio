# App
PORT=3000
NODE_ENV=development
APP_NAME=DealWatch MX
APP_URL=http://localhost:3000
JWT_SECRET=cambia-esto-por-una-clave-larga-y-segura
CRON_SECRET=cambia-esto-por-otra-clave-larga
DB_PATH=./data/dealwatch.db

# Admin inicial. Se crea automáticamente si no existe ningún admin.
ADMIN_NAME=David
ADMIN_EMAIL=tu_correo@example.com
ADMIN_PASSWORD=cambia-esta-contrasena

# Revisión de precios
DEFAULT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/124 Safari/537.36
PRICE_DROP_STRONG_PERCENT=25

# Telegram opcional
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email SMTP opcional
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=DealWatch MX <alertas@example.com>
ALERT_EMAIL_TO=
